NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres.sdwfhqvchhntectukiju:[YOUR-SUPABASE-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres
# Use the direct database host for Prisma schema operations such as db push / migrate.
DIRECT_URL=postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.sdwfhqvchhntectukiju.supabase.co:5432/postgres
# In Vercel, set this to your real frontend URL or custom domain.
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=topics_members_session
AUTH_COOKIE_MAX_AGE_DAYS=7
BCRYPT_SALT_ROUNDS=12
RESET_TOKEN_TTL_MINUTES=30
VERIFICATION_CODE_TTL_MINUTES=15
# Optional. If omitted, the backend auto-selects "resend" when
# RESEND_API_KEY and EMAIL_FROM_ADDRESS are configured; otherwise it uses "console".
EMAIL_PROVIDER=
EMAIL_FROM_NAME=TOPICS Pay
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
RESEND_API_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_WEBHOOK_URL=

# Optional admin seed
ADMIN_NAME=TOPICS Admin
ADMIN_EMAIL=admin@topicsmembers.com
ADMIN_PASSWORD=ChangeMe123!
